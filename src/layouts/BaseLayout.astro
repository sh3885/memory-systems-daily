---
import { BrainCircuit, Cpu, Database, House, PenTool, Tags } from "@lucide/astro";
import { blogSettings } from "../data/blog";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  frontmatter?: {
    title?: string;
    description?: string;
  };
}

const frontmatter = Astro.props.frontmatter ?? {};
const title = Astro.props.title ?? frontmatter.title ?? blogSettings.blogTitle;
const description = Astro.props.description ?? frontmatter.description ?? blogSettings.description;
const path = Astro.url.pathname;
const apiBase = import.meta.env.PUBLIC_BLOG_API_BASE ??
  (import.meta.env.DEV ? "" : "https://memory-systems-daily-bot.sh3885-lee.workers.dev");
const apiBaseScript = `window.MSD_API_BASE = ${JSON.stringify(apiBase)};`;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/images/memory-systems-hero.png" />
    <title>{title}</title>
  </head>
  <body>
    <script is:inline set:html={apiBaseScript}></script>
    <script is:inline src="/scripts/blog-runtime.js" defer></script>
    <header class="site-header">
      <div class="shell header-inner">
        <a class="brand" href="/" aria-label="Memory Systems Daily home">
          <span class="brand-mark">MS</span>
          <span>{blogSettings.blogTitle}</span>
        </a>
        <nav aria-label="블로그 메뉴">
          <a class:list={[{ active: path === "/" }]} href="/"><House size={16} />Home</a>
          <a class:list={[{ active: path.startsWith("/llm") }]} href="/llm/"><BrainCircuit size={16} />LLM</a>
          <a class:list={[{ active: path.startsWith("/memory") }]} href="/memory/"><Database size={16} />Memory</a>
          <a class:list={[{ active: path.startsWith("/system") }]} href="/system/"><Cpu size={16} />System</a>
          <a class:list={[{ active: path.startsWith("/tags") }]} href="/tags/"><Tags size={16} />Tags</a>
          <a class:list={[{ active: path.startsWith("/admin") }]} href="/admin/"><PenTool size={16} />Admin</a>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <div class="shell footer-inner">
        <strong>{blogSettings.blogTitle}</strong>
        <p>{blogSettings.description}</p>
      </div>
    </footer>
  </body>
</html>
