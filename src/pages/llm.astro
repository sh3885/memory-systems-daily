---
import PostList from "../components/PostList.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { categoryById, postsForCategory, tagCloud } from "../data/blog";

const category = categoryById("llm");
const categoryPosts = postsForCategory("llm");
const tags = tagCloud().filter((tag) => categoryPosts.some((post) => post.tags.includes(tag.tag)));
---

<BaseLayout title="LLM | Memory Systems Daily" description={category.description}>
  <section class="shell blog-wrap">
    <header class="blog-title compact-title">
      <p class="kicker">Category</p>
      <h1>{category.label}</h1>
      <p>{category.description}</p>
    </header>

    <div class="blog-layout">
      <PostList posts={categoryPosts} emptyText="아직 LLM 글이 없습니다." />
      <aside class="sidebar">
        <section class="side-box">
          <h2>LLM Notes</h2>
          <p>모델 구조에서 serving 병목까지, token이 움직이는 데이터 경로를 중심으로 봅니다.</p>
        </section>
        <section class="side-box">
          <h2>Tags</h2>
          <div class="tag-list">
            {tags.map(({ tag, count, path }) => <a href={path}>{tag}<span>{count}</span></a>)}
          </div>
        </section>
      </aside>
    </div>
  </section>
</BaseLayout>
