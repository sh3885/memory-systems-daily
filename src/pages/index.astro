---
import BaseLayout from "../layouts/BaseLayout.astro";
import { blogCategories, posts, postsForCategory, tagCloud } from "../data/blog";

const [featured, ...restPosts] = posts;
const tags = tagCloud();
---

<BaseLayout title="Memory Systems Daily">
  <section class="shell blog-wrap">
    <header class="blog-title">
      <p class="kicker">LLM / Memory / System</p>
      <h1>Memory Systems Daily</h1>
      <p>LLM과 메모리 시스템을 공부하며 정리하는 기술 블로그입니다.</p>
    </header>

    <div class="blog-layout">
      <section class="post-stream" aria-label="최신 글">
        {featured ? (
          <a class="post-card" href={featured.url}>
            <div class="post-thumb">
              <img src="/images/memory-systems-hero.png" alt="" loading="lazy" />
            </div>
            <div class="post-summary">
              <div class="post-meta">
                <span class:list={["pill", featured.category]}>{featured.categoryLabel}</span>
                {featured.lessonDate && <span class="pill">{featured.lessonDate}</span>}
                {featured.minutes && <span class="pill">{featured.minutes} min</span>}
              </div>
              <h2>{featured.title}</h2>
              <p>{featured.description}</p>
              <div class="post-tags">
                {featured.tags.slice(0, 5).map((tag) => <span class="pill">{tag}</span>)}
              </div>
            </div>
          </a>
        ) : (
          <div class="empty-state">아직 공개된 글이 없습니다.</div>
        )}

        {restPosts.map((post) => (
          <a class="post-card" href={post.url}>
            <div class="post-thumb">
              <img src="/images/memory-systems-hero.png" alt="" loading="lazy" />
            </div>
            <div class="post-summary">
              <div class="post-meta">
                <span class:list={["pill", post.category]}>{post.categoryLabel}</span>
                {post.lessonDate && <span class="pill">{post.lessonDate}</span>}
              </div>
              <h3>{post.title}</h3>
              <p>{post.description}</p>
              <div class="post-tags">
                {post.tags.slice(0, 4).map((tag) => <span class="pill">{tag}</span>)}
              </div>
            </div>
          </a>
        ))}
      </section>

      <aside class="sidebar" aria-label="블로그 사이드바">
        <section class="side-box">
          <h2>About</h2>
          <p>AI, DRAM/HBM, CXL, GPU/CPU architecture를 시스템 관점에서 연결해 보는 기록입니다.</p>
        </section>

        <section class="side-box">
          <h2>Categories</h2>
          <ul>
            {blogCategories.map((category) => (
              <li>
                <a class="category-link" href={category.path}>
                  <span>{category.label}</span>
                  <span>{postsForCategory(category.id).length}</span>
                </a>
              </li>
            ))}
          </ul>
        </section>

        <section class="side-box">
          <h2>Tags</h2>
          <div class="tag-list">
            {tags.map(({ tag, count }) => <span>{tag} {count}</span>)}
          </div>
        </section>

        <section class="side-box">
          <h2>Recent</h2>
          <ul>
            {posts.slice(0, 5).map((post) => (
              <li><a href={post.url}>{post.title}</a></li>
            ))}
          </ul>
        </section>
      </aside>
    </div>
  </section>
</BaseLayout>
