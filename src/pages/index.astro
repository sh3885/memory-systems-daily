---
import { Eye, FolderOpen, History, Tags } from "@lucide/astro";
import PostList from "../components/PostList.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  archiveMonths,
  blogSettings,
  orderedBlogCategories,
  posts,
  postsForCategory,
  tagCloud,
} from "../data/blog";

const tags = tagCloud();
const months = archiveMonths();
---

<BaseLayout title="Memory Systems Daily">
  <section class="shell blog-wrap">
    <header class="blog-title compact-title">
      <p class="kicker">Daily technical blog</p>
      <h1>Memory Systems Daily</h1>
      <p>{blogSettings.description}</p>
    </header>

    <div class="blog-layout">
      <PostList posts={posts} />

      <aside class="sidebar" aria-label="블로그 사이드바">
        <section class="side-box profile-box">
          <h2>About</h2>
          <p>LLM serving, memory hierarchy, system bottleneck을 공개 가능한 개념 중심으로 정리합니다.</p>
        </section>

        <section class="side-box stats-box">
          <h2><Eye size={15} /> Visitors</h2>
          <div class="stats-grid">
            <span>전체</span><strong data-visit-total>0</strong>
            <span>오늘</span><strong data-visit-today>0</strong>
            <span>고유</span><strong data-visit-unique>0</strong>
          </div>
          <p data-visit-status>API 연결 시 자동 업데이트됩니다.</p>
        </section>

        <section class="side-box">
          <h2><FolderOpen size={15} /> Categories</h2>
          <ul>
            {orderedBlogCategories.map((category) => (
              <li>
                <a class="category-link" href={category.path}>
                  <span>{category.label}</span>
                  <span>{postsForCategory(category.id).length}</span>
                </a>
              </li>
            ))}
          </ul>
        </section>

        <section class="side-box">
          <h2><Tags size={15} /> Tags</h2>
          <div class="tag-list">
            {tags.map(({ tag, count, path }) => <a href={path}>{tag}<span>{count}</span></a>)}
          </div>
        </section>

        <section class="side-box">
          <h2><History size={15} /> Archive</h2>
          <ul>
            {months.map(({ month, count }) => (
              <li class="category-link"><span>{month}</span><span>{count}</span></li>
            ))}
          </ul>
        </section>
      </aside>
    </div>
  </section>
</BaseLayout>
