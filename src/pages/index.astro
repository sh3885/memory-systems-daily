---
import {
  ArrowRight,
  BookOpen,
  CircleCheck,
  Clock3,
  MessageCircleQuestionMark,
  Send,
  Sparkles,
} from "@lucide/astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { curriculum, weeklyRhythm } from "../data/curriculum";
---

<BaseLayout title="Memory Systems Daily">
  <section class="hero">
    <div class="hero-shade"></div>
    <div class="shell hero-inner">
      <div class="hero-copy">
        <p class="eyebrow">LLM · Memory · Systems</p>
        <h1>Memory Systems<br />Daily</h1>
        <p class="hero-lead">LLM의 token부터 DRAM의 row까지, 데이터가 움직이는 전체 시스템을 매일 한 단계씩 공부합니다.</p>
        <div class="hero-actions">
          <a class="button" href="/posts/llm-next-token"><BookOpen size={18} />오늘 학습 시작</a>
          <a class="button secondary" href="/roadmap">전체 과정 보기<ArrowRight size={18} /></a>
        </div>
      </div>
    </div>
  </section>

  <section class="today-band">
    <div class="shell today-grid">
      <article class="lesson-panel">
        <div class="lesson-meta">
          <span class="tag"><Sparkles size={14} />DAY 01 · LLM 기초</span>
          <span><Clock3 size={15} />약 18분</span>
        </div>
        <p class="lesson-kicker">오늘의 질문</p>
        <h2>LLM은 어떻게 다음 Token을 예측하는가?</h2>
        <p>문장을 token으로 나누고, 마지막 위치의 확률분포에서 다음 token을 선택하는 과정을 tensor shape와 함께 살펴봅니다.</p>
        <div class="lesson-points">
          <span>Token과 vocabulary</span>
          <span>Logit과 probability</span>
          <span>Autoregressive decode</span>
          <span>Weight read와 memory traffic</span>
        </div>
        <a class="text-link" href="/posts/llm-next-token">학습 노트 열기 <ArrowRight size={17} /></a>
      </article>

      <aside class="telegram" aria-label="Telegram 학습 알림 예시">
        <div class="telegram-head">
          <div class="bot-avatar"><Send size={20} /></div>
          <div><strong>Memory Study Bot</strong><span>매일 08:30 KST</span></div>
          <span class="online">자동화 준비</span>
        </div>
        <div class="chat-body">
          <div class="message bot-message">
            <small>오늘의 학습 카드</small>
            <strong>LLM은 어떻게 다음 Token을 예측할까요?</strong>
            <p>먼저 3분 요약을 읽고, 이해가 막히는 지점을 바로 질문하세요.</p>
          </div>
          <div class="message user-message">Logit과 확률은 같은 값인가요?</div>
          <div class="message bot-message compact">아닙니다. Logit은 정규화 전 점수이고, softmax를 통과한 값이 확률입니다. 작은 숫자 예제로 다시 볼까요?</div>
          <div class="chat-actions">
            <button><MessageCircleQuestionMark size={15} />쉽게 설명</button>
            <button><CircleCheck size={15} />퀴즈</button>
            <button class="approve"><CircleCheck size={15} />발행 승인</button>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section class="system-band">
    <div class="shell">
      <div class="section-title">
        <p class="eyebrow">ONE CONNECTED CURRICULUM</p>
        <h2>LLM만 배우지 않습니다</h2>
        <p>컴퓨터 구조와 DRAM에서 시작해 LLM, GPU, 네트워크, CXL, 차세대 메모리까지 하나의 데이터 경로로 연결합니다.</p>
      </div>
      <div class="track-map">
        {curriculum.slice(0, 6).map((item) => (
          <div class:list={["track-item", item.color]}>
            <span>{item.index}</span>
            <div><small>{item.weeks}</small><strong>{item.title}</strong></div>
          </div>
        ))}
        <a class="track-more" href="/roadmap">06개 모듈 더 보기 <ArrowRight size={18} /></a>
      </div>
    </div>
  </section>

  <section class="rhythm-band">
    <div class="shell">
      <div class="section-title">
        <p class="eyebrow">WEEKLY RHYTHM</p>
        <h2>매일 쓰되, 매일 다른 방식으로 배웁니다</h2>
      </div>
      <div class="week-grid">
        {weeklyRhythm.map(([day, title, detail]) => (
          <div class="day-row">
            <span>{day}</span>
            <strong>{title}</strong>
            <p>{detail}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    min-height: min(590px, calc(100vh - 66px));
    overflow: hidden;
    border-bottom: 1px solid var(--line);
    background-color: white;
    background-image: url("/images/memory-systems-hero.png");
    background-position: center;
    background-size: cover;
  }

  .hero-shade {
    position: absolute;
    inset: 0 46% 0 0;
    background: rgba(255, 255, 255, 0.78);
  }

  .hero-inner {
    position: relative;
    display: flex;
    min-height: inherit;
    align-items: center;
  }

  .hero-copy {
    width: min(540px, 52%);
    padding: 56px 0 82px;
  }

  .hero h1 {
    margin-bottom: 18px;
    font-size: clamp(3.2rem, 7vw, 6.2rem);
    font-weight: 880;
  }

  .hero-lead {
    max-width: 510px;
    color: #44514b;
    font-size: 1.08rem;
  }

  .hero-actions {
    display: flex;
    gap: 10px;
    margin-top: 28px;
  }

  .today-band,
  .system-band,
  .rhythm-band {
    padding: 84px 0;
  }

  .today-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(340px, 0.85fr);
    gap: 56px;
    align-items: start;
  }

  .lesson-panel {
    padding-top: 8px;
  }

  .lesson-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    color: var(--muted);
    font-size: 0.82rem;
  }

  .lesson-meta > span {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .lesson-kicker {
    margin: 44px 0 7px;
    color: var(--muted);
    font-size: 0.84rem;
    font-weight: 750;
  }

  .lesson-panel h2 {
    max-width: 680px;
    margin-bottom: 18px;
    font-size: clamp(2rem, 4vw, 3.4rem);
  }

  .lesson-panel > p:not(.lesson-kicker) {
    max-width: 680px;
    color: var(--muted);
  }

  .lesson-points {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin: 28px 0;
    border-top: 1px solid var(--line);
  }

  .lesson-points span {
    padding: 12px 0;
    border-bottom: 1px solid var(--line);
    font-size: 0.88rem;
    font-weight: 720;
  }

  .text-link {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    color: var(--green);
    font-weight: 800;
  }

  .telegram {
    overflow: hidden;
    border: 1px solid #cfd6db;
    border-radius: 8px;
    background: #e8edf1;
    box-shadow: 0 18px 50px rgba(29, 48, 61, 0.12);
  }

  .telegram-head {
    display: flex;
    min-height: 70px;
    align-items: center;
    gap: 11px;
    padding: 12px 14px;
    background: white;
  }

  .bot-avatar {
    display: grid;
    width: 42px;
    height: 42px;
    flex: 0 0 42px;
    place-items: center;
    border-radius: 50%;
    background: var(--blue);
    color: white;
  }

  .telegram-head div:nth-child(2) {
    display: grid;
  }

  .telegram-head span {
    color: var(--muted);
    font-size: 0.72rem;
  }

  .telegram-head .online {
    margin-left: auto;
    color: var(--green);
    font-weight: 800;
  }

  .chat-body {
    display: flex;
    min-height: 435px;
    flex-direction: column;
    gap: 10px;
    padding: 18px;
    background-color: #dfe7eb;
    background-image: radial-gradient(#c6d2d8 0.8px, transparent 0.8px);
    background-size: 14px 14px;
  }

  .message {
    max-width: 88%;
    padding: 11px 13px;
    border-radius: 7px;
    background: white;
    box-shadow: 0 1px 2px rgba(35, 56, 70, 0.09);
    font-size: 0.83rem;
  }

  .message small,
  .message strong {
    display: block;
    margin-bottom: 5px;
  }

  .message small {
    color: var(--blue);
    font-weight: 800;
  }

  .message p {
    margin: 0;
    color: var(--muted);
  }

  .user-message {
    align-self: flex-end;
    background: #d9f4c7;
  }

  .compact {
    margin-bottom: 6px;
  }

  .chat-actions {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 7px;
    margin-top: auto;
  }

  .chat-actions button {
    display: inline-flex;
    min-height: 39px;
    align-items: center;
    justify-content: center;
    gap: 6px;
    border: 1px solid #c9d1d5;
    border-radius: 5px;
    background: white;
    color: #24608b;
    font: inherit;
    font-size: 0.76rem;
    font-weight: 800;
  }

  .chat-actions .approve {
    grid-column: 1 / -1;
    border-color: var(--green);
    background: var(--green);
    color: white;
  }

  .system-band {
    border-block: 1px solid var(--line);
    background: white;
  }

  .track-map {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--line);
  }

  .track-item,
  .track-more {
    display: flex;
    min-height: 120px;
    align-items: center;
    gap: 16px;
    padding: 22px;
    background: white;
  }

  .track-item > span {
    display: grid;
    width: 38px;
    height: 38px;
    flex: 0 0 38px;
    place-items: center;
    border-radius: 5px;
    font-size: 0.78rem;
    font-weight: 850;
  }

  .track-item.green > span { background: var(--green-soft); color: var(--green); }
  .track-item.blue > span { background: var(--blue-soft); color: var(--blue); }
  .track-item.amber > span { background: var(--amber-soft); color: var(--amber); }
  .track-item.red > span { background: var(--red-soft); color: var(--red); }

  .track-item div {
    display: grid;
    gap: 4px;
  }

  .track-item small {
    color: var(--muted);
  }

  .track-more {
    justify-content: center;
    background: var(--ink);
    color: white;
    font-weight: 800;
  }

  .week-grid {
    border-top: 1px solid var(--ink);
  }

  .day-row {
    display: grid;
    grid-template-columns: 80px 180px 1fr;
    gap: 18px;
    align-items: center;
    min-height: 70px;
    border-bottom: 1px solid var(--line);
  }

  .day-row > span {
    color: var(--green);
    font-size: 0.75rem;
    font-weight: 850;
  }

  .day-row p {
    margin: 0;
    color: var(--muted);
    font-size: 0.88rem;
  }

  @media (max-width: 900px) {
    .hero {
      min-height: 570px;
      background-position: 58% center;
    }

    .hero-shade {
      inset: 0 34% 0 0;
      background: rgba(255, 255, 255, 0.84);
    }

    .hero-copy {
      width: 66%;
    }

    .today-grid {
      grid-template-columns: 1fr;
    }

    .telegram {
      width: min(100%, 560px);
    }

    .track-map {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 620px) {
    .hero {
      min-height: 610px;
      background-position: 61% 70%;
      background-size: auto 76%;
      background-repeat: no-repeat;
    }

    .hero-shade {
      inset: 0;
      background: rgba(255, 255, 255, 0.68);
    }

    .hero-inner {
      align-items: flex-start;
    }

    .hero-copy {
      width: 100%;
      padding: 54px 0 190px;
    }

    .hero h1 {
      font-size: 3.25rem;
    }

    .hero-lead {
      font-size: 0.98rem;
    }

    .hero-actions {
      display: grid;
    }

    .today-band,
    .system-band,
    .rhythm-band {
      padding: 62px 0;
    }

    .today-grid {
      gap: 42px;
    }

    .lesson-points,
    .track-map {
      grid-template-columns: 1fr;
    }

    .day-row {
      grid-template-columns: 55px 1fr;
      gap: 10px;
      padding: 14px 0;
    }

    .day-row p {
      grid-column: 2;
    }
  }
</style>
