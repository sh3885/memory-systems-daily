---
import PostList from "../components/PostList.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { categoryById, postsForCategory, tagCloud } from "../data/blog";

const category = categoryById("system");
const categoryPosts = postsForCategory("system");
const tags = tagCloud().filter((tag) => categoryPosts.some((post) => post.tags.includes(tag.tag)));
---

<BaseLayout title="System | Memory Systems Daily" description={category.description}>
  <section class="shell blog-wrap">
    <header class="blog-title compact-title">
      <p class="kicker">Category</p>
      <h1>{category.label}</h1>
      <p>{category.description}</p>
    </header>

    <div class="blog-layout">
      <PostList posts={categoryPosts} emptyText="아직 System 글이 없습니다." />
      <aside class="sidebar">
        <section class="side-box">
          <h2>System Notes</h2>
          <p>CPU/GPU, cache, interconnect, I/O를 성능 분석 관점에서 정리합니다.</p>
        </section>
        <section class="side-box">
          <h2>Tags</h2>
          <div class="tag-list">
            {tags.map(({ tag, count, path }) => <a href={path}>{tag}<span>{count}</span></a>)}
          </div>
        </section>
      </aside>
    </div>
  </section>
</BaseLayout>
