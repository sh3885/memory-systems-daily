---
import { ArrowRight, Beaker, BookOpenCheck, CircleCheckBig, FileText, SearchCheck } from "@lucide/astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { curriculum, curriculumQualityGate, dailyLessons, postBlueprints, weeklyRhythm } from "../data/curriculum";
---

<BaseLayout title="전체 과정 | Memory Systems Daily">
  <header class="page-head">
    <div class="shell page-head-inner">
      <div>
        <p class="eyebrow">36-WEEK ROADMAP</p>
        <h1>LLM에서<br />메모리 시스템까지</h1>
      </div>
      <p>
        단순히 매일 글 하나를 쓰는 과정이 아니라, LLM workload를 tensor shape, byte traffic,
        DRAM/HBM/CXL 계층, GPU/CPU 데이터 경로로 계속 번역하는 학습 시스템입니다.
      </p>
    </div>
  </header>

  <section class="overview">
    <div class="shell overview-grid">
      <div><strong>36주</strong><span>기초부터 시스템 종합까지</span></div>
      <div><strong>252일</strong><span>매일 생성 가능한 lesson ref</span></div>
      <div><strong>28일</strong><span>첫 달 상세 lesson 설계 완료</span></div>
      <div><strong>5종</strong><span>글 템플릿과 품질 게이트</span></div>
    </div>
  </section>

  <section class="curriculum-section">
    <div class="shell">
      <div class="section-title">
        <p class="eyebrow">FULL CURRICULUM</p>
        <h2>큰 지도는 12개 모듈, 실제 포스팅은 일별 lesson으로 갑니다</h2>
        <p>각 모듈은 주제 방향을 잡고, 일별 lesson은 질문, 계산, 실험, 그림, 출처 후보까지 포함합니다.</p>
      </div>
      <div class="curriculum-list">
        {curriculum.map((item) => (
          <article class:list={["module", item.color]}>
            <div class="module-id"><span>{item.index}</span><small>{item.weeks}</small></div>
            <div class="module-main">
              <h3>{item.title}</h3>
              <p class="question">{item.question}</p>
              <div class="topics">
                {item.topics.map((topic) => <span>{topic}</span>)}
              </div>
            </div>
            <div class="module-output">
              <div><Beaker size={17} /><p><small>실습</small>{item.lab}</p></div>
              <div><CircleCheckBig size={17} /><p><small>완료 기준</small>{item.outcome}</p></div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="detail-section">
    <div class="shell">
      <div class="section-title">
        <p class="eyebrow">FIRST 4 WEEKS IN DETAIL</p>
        <h2>첫 달은 이미 매일 쓸 수 있는 수준으로 쪼개져 있습니다</h2>
        <p>아래 한 줄이 하루 포스팅 하나입니다. Claude에 넘길 때도 이 데이터를 기반으로 질문, 계산표, 그림 요구사항, 출처 후보가 같이 들어가야 합니다.</p>
      </div>
      <div class="lesson-list">
        {dailyLessons.map((lesson) => (
          <article class="lesson-row">
            <div class="lesson-key">
              <span>{lesson.ref}</span>
              <small>W{lesson.week} · {lesson.day}</small>
            </div>
            <div class="lesson-body">
              <h3>{lesson.title}</h3>
              <p class="core-question">{lesson.coreQuestion}</p>
              <div class="lesson-tags">
                {lesson.concepts.map((concept) => <span>{concept}</span>)}
              </div>
              <div class="lesson-grid">
                <p><strong>계산/실험</strong>{lesson.practice}</p>
                <p><strong>산출물</strong>{lesson.artifact}</p>
                <p><strong>글 섹션</strong>{lesson.postSections.join(" / ")}</p>
              </div>
            </div>
            <div class="source-box">
              <SearchCheck size={17} />
              <div>
                <strong>출처 후보</strong>
                {lesson.sourceHints.slice(0, 2).map((source) => <a href={source}>{source.replace(/^https?:\/\//, "")}</a>)}
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="blueprint-section">
    <div class="shell blueprint-grid">
      <div>
        <div class="section-title compact-title">
          <p class="eyebrow">POST BLUEPRINTS</p>
          <h2>글만 길게 쓰지 않기 위한 구조</h2>
          <p>매일 같은 형식으로 찍어내는 것이 아니라, 주제에 맞는 글 타입을 골라 계산과 산출물을 강제합니다.</p>
        </div>
        <div class="blueprint-list">
          {postBlueprints.map((blueprint) => (
            <article>
              <FileText size={17} />
              <div>
                <h3>{blueprint.type}</h3>
                <p>{blueprint.purpose}</p>
                <small>{blueprint.requiredBlocks.join(" · ")}</small>
              </div>
            </article>
          ))}
        </div>
      </div>
      <aside class="quality-panel">
        <BookOpenCheck size={22} />
        <h2>품질 게이트</h2>
        <ul>
          {curriculumQualityGate.map((rule) => <li>{rule}</li>)}
        </ul>
      </aside>
    </div>
  </section>

  <section class="daily-section">
    <div class="shell daily-grid">
      <div class="section-title">
        <p class="eyebrow">DAILY OPERATING SYSTEM</p>
        <h2>매일 다른 관점으로 같은 시스템을 파고듭니다</h2>
        <p>LLM 개념, 메모리 경로, 계산, 인터페이스, 최신 자료, 실험, 종합을 반복해서 얕은 요약이 되지 않게 만듭니다.</p>
        <a class="button" href="/automation">자동화 흐름 보기 <ArrowRight size={18} /></a>
      </div>
      <div class="rhythm-list">
        {weeklyRhythm.map(([day, title, detail], index) => (
          <div><span>{index + 1}</span><strong>{day} · {title}</strong><p>{detail}</p></div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-head {
    padding: 90px 0 70px;
    border-bottom: 1px solid var(--line);
    background: white;
  }

  .page-head-inner {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.95fr);
    gap: 80px;
    align-items: end;
  }

  .page-head h1 {
    margin: 0;
    font-size: clamp(3rem, 7vw, 6rem);
  }

  .page-head-inner > p {
    margin-bottom: 10px;
    color: var(--muted);
    font-size: 1.08rem;
  }

  .overview {
    border-bottom: 1px solid var(--line);
  }

  .overview-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
  }

  .overview-grid > div {
    display: grid;
    gap: 3px;
    padding: 26px 20px;
    border-right: 1px solid var(--line);
  }

  .overview-grid > div:first-child { border-left: 1px solid var(--line); }
  .overview-grid strong { font-size: 1.55rem; }
  .overview-grid span { color: var(--muted); font-size: 0.78rem; }

  .curriculum-section,
  .detail-section,
  .blueprint-section,
  .daily-section {
    padding: 88px 0;
  }

  .curriculum-list,
  .lesson-list {
    border-top: 1px solid var(--ink);
  }

  .module {
    display: grid;
    grid-template-columns: 110px minmax(0, 1.05fr) minmax(300px, 0.95fr);
    gap: 32px;
    padding: 30px 0;
    border-bottom: 1px solid var(--line);
  }

  .module-id {
    display: grid;
    align-content: start;
    gap: 7px;
  }

  .module-id span {
    display: grid;
    width: 46px;
    height: 46px;
    place-items: center;
    border-radius: 5px;
    font-size: 0.88rem;
    font-weight: 850;
  }

  .green .module-id span { background: var(--green-soft); color: var(--green); }
  .blue .module-id span { background: var(--blue-soft); color: var(--blue); }
  .amber .module-id span { background: var(--amber-soft); color: var(--amber); }
  .red .module-id span { background: var(--red-soft); color: var(--red); }

  .module-id small { color: var(--muted); }
  .module h3, .lesson-row h3 { margin-bottom: 7px; font-size: 1.22rem; }
  .question, .core-question { color: var(--muted); font-size: 0.9rem; }

  .topics,
  .lesson-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .topics span,
  .lesson-tags span {
    padding: 4px 7px;
    border: 1px solid var(--line);
    border-radius: 4px;
    background: white;
    font-size: 0.73rem;
    font-weight: 700;
  }

  .module-output {
    display: grid;
    gap: 14px;
  }

  .module-output > div {
    display: flex;
    gap: 10px;
    color: var(--muted);
  }

  .module-output svg { flex: 0 0 auto; margin-top: 3px; color: var(--ink); }
  .module-output p { margin: 0; font-size: 0.8rem; }
  .module-output small { display: block; margin-bottom: 2px; color: var(--ink); font-weight: 800; }

  .detail-section {
    border-top: 1px solid var(--line);
    background: white;
  }

  .lesson-row {
    display: grid;
    grid-template-columns: 150px minmax(0, 1fr) minmax(230px, 0.38fr);
    gap: 24px;
    padding: 24px 0;
    border-bottom: 1px solid var(--line);
  }

  .lesson-key {
    display: grid;
    align-content: start;
    gap: 6px;
  }

  .lesson-key span {
    color: var(--green);
    font-size: 0.83rem;
    font-weight: 850;
  }

  .lesson-key small,
  .source-box a,
  .blueprint-list small {
    color: var(--muted);
    font-size: 0.72rem;
  }

  .lesson-body {
    display: grid;
    gap: 10px;
  }

  .lesson-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
  }

  .lesson-grid p {
    margin: 0;
    padding: 10px;
    border-left: 2px solid var(--line);
    color: var(--muted);
    font-size: 0.76rem;
  }

  .lesson-grid strong,
  .source-box strong {
    display: block;
    margin-bottom: 4px;
    color: var(--ink);
    font-size: 0.72rem;
  }

  .source-box {
    display: flex;
    gap: 9px;
    align-items: start;
    color: var(--ink);
  }

  .source-box svg {
    flex: 0 0 auto;
    margin-top: 2px;
    color: var(--blue);
  }

  .source-box a {
    display: block;
    overflow-wrap: anywhere;
    line-height: 1.45;
  }

  .blueprint-section,
  .daily-section {
    border-top: 1px solid var(--line);
    background: white;
  }

  .blueprint-grid,
  .daily-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(340px, 0.55fr);
    gap: 64px;
  }

  .compact-title {
    margin-bottom: 26px;
  }

  .blueprint-list {
    display: grid;
    gap: 1px;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--line);
  }

  .blueprint-list article {
    display: flex;
    gap: 12px;
    padding: 18px;
    background: white;
  }

  .blueprint-list svg {
    flex: 0 0 auto;
    margin-top: 3px;
    color: var(--green);
  }

  .blueprint-list h3 {
    margin-bottom: 4px;
    font-size: 0.98rem;
  }

  .blueprint-list p {
    margin: 0 0 6px;
    color: var(--muted);
    font-size: 0.82rem;
  }

  .quality-panel {
    align-self: start;
    padding: 24px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #f7faf8;
  }

  .quality-panel svg {
    color: var(--green);
  }

  .quality-panel h2 {
    margin: 12px 0;
    font-size: 1.35rem;
  }

  .quality-panel ul {
    display: grid;
    gap: 9px;
    margin: 0;
    padding-left: 18px;
    color: var(--muted);
    font-size: 0.82rem;
  }

  .rhythm-list {
    border-top: 1px solid var(--ink);
  }

  .rhythm-list > div {
    display: grid;
    grid-template-columns: 34px 180px 1fr;
    gap: 12px;
    align-items: center;
    padding: 13px 0;
    border-bottom: 1px solid var(--line);
  }

  .rhythm-list span { color: var(--green); font-size: 0.75rem; font-weight: 850; }
  .rhythm-list strong { font-size: 0.82rem; }
  .rhythm-list p { margin: 0; color: var(--muted); font-size: 0.76rem; }

  @media (max-width: 960px) {
    .page-head-inner,
    .blueprint-grid,
    .daily-grid {
      grid-template-columns: 1fr;
      gap: 34px;
    }

    .module {
      grid-template-columns: 80px 1fr;
    }

    .module-output {
      grid-column: 2;
    }

    .lesson-row {
      grid-template-columns: 110px 1fr;
    }

    .source-box {
      grid-column: 2;
    }

    .lesson-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 620px) {
    .page-head { padding: 62px 0 48px; }
    .overview-grid { grid-template-columns: repeat(2, 1fr); }
    .overview-grid > div:nth-child(3) { border-left: 1px solid var(--line); }
    .curriculum-section, .detail-section, .blueprint-section, .daily-section { padding: 64px 0; }

    .module,
    .lesson-row {
      grid-template-columns: 1fr;
      gap: 14px;
      padding: 24px 0;
    }

    .module-id {
      grid-template-columns: 46px 1fr;
      align-items: center;
    }

    .module-id span { width: 42px; height: 42px; }
    .module-output, .source-box { grid-column: auto; }
    .rhythm-list > div { grid-template-columns: 28px 1fr; }
    .rhythm-list p { grid-column: 2; }
  }
</style>
